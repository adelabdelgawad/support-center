{
  "dashboard": {
    "id": null,
    "title": "Security Metrics",
    "tags": ["support-center", "security"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Failed Login Attempts",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(support_center_login_failed_total[5m])) by (status_code)",
            "legendFormat": "{{ status_code }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "red",
              "value": 10
            }
          ]
        }
      },
      {
        "id": 2,
        "title": "Fingerprint Mismatches",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(support_center_desktop_security_event_total{event_type=\"fingerprint_mismatch\"}[5m]))",
            "legendFormat": "Fingerprint Mismatches"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "yellow",
              "value": 1
            },
            {
              "color": "red",
              "value": 5
            }
          ]
        }
      },
      {
        "id": 3,
        "title": "Country Changes",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(support_center_desktop_security_event_total{event_type=\"country_change\"}[5m]))",
            "legendFormat": "Country Changes"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "yellow",
              "value": 1
            },
            {
              "color": "red",
              "value": 5
            }
          ]
        }
      },
      {
        "id": 4,
        "title": "Circuit Breaker State",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(support_center_circuit_breaker_state{state=\"closed\"})",
            "legendFormat": "Closed"
          },
          {
            "expr": "sum(support_center_circuit_breaker_state{state=\"open\"})",
            "legendFormat": "Open"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "mappings": [
              {
                "options": {
                  "closed": {
                    "color": "green",
                    "index": 0,
                    "text": "CLOSED"
                  },
                  "open": {
                    "color": "red",
                    "index": 1,
                    "text": "OPEN"
                  }
                },
                "type": "value"
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "unit": "short"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          },
          "text": {}
        }
      },
      {
        "id": 5,
        "title": "Security Events Summary",
        "type": "table",
        "targets": [
          {
            "expr": "sum(support_center_desktop_security_event_total{event_type=~\"fingerprint_mismatch|country_change|suspicious_activity\"}) by (event_type)",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "custom": {
              "align": null,
              "displayMode": "auto",
              "filterable": false
            },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": 0
                },
                {
                  "color": "yellow",
                  "value": 10
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            },
            "unit": "short"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "value"
              },
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "lcd-gauge"
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 16
        },
        "options": {
          "showHeader": true,
          "sortBy": [],
          "sortDisplayMode": "auto",
          "sortOrder": "desc"
        }
      },
      {
        "id": 6,
        "title": "Failed Login by IP",
        "type": "bar gauge",
        "targets": [
          {
            "expr": "topk(10, sum(support_center_login_failed_total) by (source_ip))",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "custom": {
              "align": null,
              "displayMode": "auto"
            },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 20
                }
              ]
            },
            "unit": "short"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        },
        "options": {
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          },
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 7,
        "title": "Security Alert Score",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(support_center_desktop_security_event_total{event_type=~\"fingerprint_mismatch|country_change|suspicious_activity\"}) / 10",
            "legendFormat": "Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "custom": {
              "axisLabel": "",
              "axisPlacement": "bottom",
              "barAlignment": 0,
              "drawStyle": "bars",
              "fillOpacity": 100,
              "gradientMode": "none",
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              },
              "lineInterpolation": "linear",
              "lineWidth": 1,
              "pointSize": 5,
              "scale": "linear",
              "showPoints": "never",
              "spanNulls": false,
              "stacking": {
                "group": "A",
                "mode": "none"
              }
            },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": 0
                },
                {
                  "color": "yellow",
                  "value": 2
                },
                {
                  "color": "red",
                  "value": 5
                }
              ]
            },
            "unit": "short"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        },
        "options": {
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          },
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": [
        "5s",
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ]
    },
    "templating": {
      "list": [
        {
          "name": "timeRange",
          "type": "custom",
          "query": "1h,6h,12h,24h,2d,7d,30d",
          "current": {
            "selected": false,
            "text": "1h",
            "value": "1h"
          }
        }
      ]
    }
  }
}